{
  "name": "index-ai-validator",
  "version": "0.1.0",
  "private": true,
  "description": "index-ai-validator monorepo: validator package and docs for the experimental index-ai Level 1 and Level 2a specification.",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "turbo run dev",
    "check": "turbo run check",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\" \"!**/dist/**\"",
    "format": "prettier --write \"*.json\" \"*.md\" \"docs/**/*.md\" \"packages/validator/**/*.{ts,json,md}\"",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "validator:dev": "pnpm --filter @hardmachinelabs/index-ai-validator dev",
    "validator:build": "pnpm --filter @hardmachinelabs/index-ai-validator build",
    "validator:test": "pnpm --filter @hardmachinelabs/index-ai-validator test",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "markdownlint-cli2": "catalog:",
    "mermaid": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "vitepress": "catalog:",
    "vitepress-plugin-mermaid": "catalog:",
    "vue": "catalog:"
  }
}
